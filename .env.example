# Database Connection (TimescaleDB / Postgres)
POSTGRES_URI=postgresql://username:password@localhost:5432/sports_db

# Cache / Message Broker (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Proxies for Scrapers
PROXY_NETWORK_URL=http://username:password@proxy_provider.com:port

# Sharp Bookmaker API Access
SHARP_BOOK_API_KEY=your_sharp_book_api_key_here

# LLM API (for news parsing/sentiment analysis or agents)
LLM_API_KEY=your_llm_api_key_here
